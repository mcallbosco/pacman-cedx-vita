# Build outputs (anchored so we don't clobber the hand-written Makefiles
# inside lib/vitaGL/ and lib/vitaGL_clean/)
/build/
/build.bak/
/CMakeFiles/
/CMakeCache.txt
/cmake_install.cmake
*.elf
*.velf
/*.bin
/*.sfo
/eboot.bin

# Crash dumps + logs
coredump*
logs/
artifacts/

# Editor / harness state
.codex
.claude/
.idea/
.vscode/

# vitaGL build artifacts (regenerated by the CMake custom-command on first build)
lib/vitaGL/libvitaGL.a
lib/vitaGL_clean/libvitaGL.a
lib/vitaGL/source/**/*.o
lib/vitaGL_clean/source/**/*.o

# Ignored: precompiled vitaGL drop (not used by CMakeLists.txt)
lib/vitaGL_precompiled/

# OS junk
.DS_Store
Thumbs.db

# === DO NOT COMMIT GAME DATA ===
# libPacmanCE.so / libfmod.so and the assets/ tree are Bandai Namco's
# property. Users must supply their own APK + OBB. Anything matching the
# patterns below is blocked from being staged by accident.
*.apk
*.obb
libPacmanCE.so
libfmod.so
**/lib/armeabi-v7a/
**/assets/**/*.png
**/assets/**/*.gxt
**/assets/**/*.fsb
**/assets/data/
docs/pacmancedx-data.zip
